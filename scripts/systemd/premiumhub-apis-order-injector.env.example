# Copy to: /etc/default/premiumhub-apis-order-injector
# Tune safely; default service already uses conservative values.

# target account
TARGET_EMAIL=apis@lokal.com

# injected order shape
PROVIDER_STATUS=TIMEOUT
ORDER_TYPE=activation
COUNTRY=indonesia
OPERATOR=indo
PRODUCT=tiktok

# speed control
ROWS_PER_TICK=1
LOOP_INTERVAL_SEC=1

# stop automatically after N rows (0 = unlimited)
MAX_INSERT=0

# keep resolved_at populated for terminal statuses
ENABLE_RESOLVED_AT=1

# DB safety guard (milliseconds)
PGLOCK_TIMEOUT_MS=250
PGSTATEMENT_TIMEOUT_MS=2500
