# App
APP_PORT=8080
APP_ENV=development

# Database
DB_HOST=127.0.0.1
DB_PORT=5435
DB_USER=premiumhub
DB_PASSWORD=replace-me
DB_NAME=premiumhub

# Auth
JWT_SECRET=replace-with-random-32chars-minimum
JWT_EXPIRY=24h
GOOGLE_CLIENT_ID=
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW=1m

# Convert endpoint rate limits
CONVERT_TRACK_RATE_LIMIT_MAX=120
CONVERT_TRACK_RATE_LIMIT_WINDOW=1m
CONVERT_CREATE_RATE_LIMIT_MAX=12
CONVERT_CREATE_RATE_LIMIT_WINDOW=1m
CONVERT_PROOF_RATE_LIMIT_MAX=20
CONVERT_PROOF_RATE_LIMIT_WINDOW=5m
CONVERT_ADMIN_STATUS_RATE_LIMIT_MAX=120
CONVERT_ADMIN_STATUS_RATE_LIMIT_WINDOW=1m

# Convert auto-expire worker
CONVERT_EXPIRY_WORKER_ENABLED=true
CONVERT_EXPIRY_WORKER_INTERVAL=1m
CONVERT_EXPIRY_WORKER_BATCH_LIMIT=200

# Convert proof storage
# mode: local | r2
CONVERT_PROOF_STORAGE_MODE=local
CONVERT_PROOF_LOCAL_DIR=runtime/convert-proofs
CONVERT_PROOF_MAX_FILE_MB=10

# R2 settings (dipakai jika CONVERT_PROOF_STORAGE_MODE=r2)
CONVERT_PROOF_R2_ENDPOINT=
CONVERT_PROOF_R2_BUCKET=
CONVERT_PROOF_R2_REGION=auto
CONVERT_PROOF_R2_ACCESS_KEY_ID=
CONVERT_PROOF_R2_SECRET_ACCESS_KEY=
# Optional: public URL base untuk akses bukti (contoh custom domain)
CONVERT_PROOF_R2_PUBLIC_BASE_URL=
CONVERT_PROOF_R2_PREFIX=convert-proofs
CONVERT_PROOF_R2_UPLOAD_TIMEOUT=45s

# Cookie
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# Payment providers (isi sesuai environment)
PAKASIR_BASE_URL=https://app.pakasir.com
PAKASIR_PROJECT=
PAKASIR_API_KEY=
PAKASIR_HTTP_TIMEOUT_SEC=12
FIVESIM_BASE_URL=https://5sim.net/v1
FIVESIM_API_KEY=
FIVESIM_HTTP_TIMEOUT_SEC=15
# Konversi harga provider 5sim ke unit wallet internal
FIVESIM_WALLET_PRICE_MULTIPLIER=1
FIVESIM_WALLET_MIN_DEBIT=1
# Worker auto-sync + auto-cancel/refund order 5sim
FIVESIM_RECONCILE_WORKER_ENABLED=true
FIVESIM_RECONCILE_WORKER_INTERVAL=1m
FIVESIM_RECONCILE_WORKER_BATCH_LIMIT=200
FIVESIM_RECONCILE_SYNC_MIN_AGE=45s
FIVESIM_ORDER_MAX_WAITING_DURATION=15m
# Force-resolve order open jika provider terus balikin not found
FIVESIM_RESOLVE_NOT_FOUND_THRESHOLD=3
FIVESIM_RESOLVE_NOT_FOUND_MIN_AGE=3m
WALLET_TOPUP_EXPIRY_MINUTES=15
# Worker auto-reconcile topup pending
WALLET_TOPUP_RECONCILE_WORKER_ENABLED=true
WALLET_TOPUP_RECONCILE_WORKER_INTERVAL=1m
WALLET_TOPUP_RECONCILE_WORKER_BATCH_LIMIT=200

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
