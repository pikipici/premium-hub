#!/usr/bin/env bash
set -Eeuo pipefail

# =============================================================
# Premium Hub Workspace Deploy Script (isolated + deterministic)
# - ONLY targets workspace services
# - NEVER touches runtime services (premiumhub-*.service)
# - Deterministic build plan from git delta vs last successful deploy
# - Can be triggered locally via SSH; execution still happens on server
# =============================================================

# ---------- Terminal colors ----------
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  NC='\033[0m'
else
  RED=''
  GREEN=''
  YELLOW=''
  BLUE=''
  NC=''
fi

log_info() { echo -e "${BLUE}[INFO]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_ok()   { echo -e "${GREEN}[OK]${NC} $*"; }
log_err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }

DEPLOY_START_TS="$(date +%s)"
CURRENT_STEP_NAME=""
CURRENT_STEP_START_TS=0
CHANGED_FILES_TMP=""

format_duration() {
  local total_sec="${1:-0}"
  local h=$((total_sec / 3600))
  local m=$(((total_sec % 3600) / 60))
  local s=$((total_sec % 60))

  if ((h > 0)); then
    printf "%dh %dm %02ds" "${h}" "${m}" "${s}"
  elif ((m > 0)); then
    printf "%dm %02ds" "${m}" "${s}"
  else
    printf "%ds" "${s}"
  fi
}

step_start() {
  CURRENT_STEP_NAME="$1"
  CURRENT_STEP_START_TS="$(date +%s)"
  log_info "===== ${CURRENT_STEP_NAME}: START ====="
}

step_done() {
  local step_name="${1:-${CURRENT_STEP_NAME}}"
  local step_end_ts="$(date +%s)"
  local step_elapsed=0

  if [[ "${CURRENT_STEP_START_TS}" =~ ^[0-9]+$ ]] && ((CURRENT_STEP_START_TS > 0)); then
    step_elapsed=$((step_end_ts - CURRENT_STEP_START_TS))
  fi

  log_ok "===== ${step_name}: DONE ($(format_duration "${step_elapsed}")) ====="
  CURRENT_STEP_NAME=""
  CURRENT_STEP_START_TS=0
}

cleanup_temp() {
  if [[ -n "${CHANGED_FILES_TMP}" && -f "${CHANGED_FILES_TMP}" ]]; then
    rm -f "${CHANGED_FILES_TMP}"
  fi
}
trap cleanup_temp EXIT

on_error() {
  local line="$1"
  local cmd="$2"
  local code="$3"
  local now_ts="$(date +%s)"
  local total_elapsed=$((now_ts - DEPLOY_START_TS))

  log_err "Workspace deploy gagal di line ${line} (exit ${code})"
  log_err "Command: ${cmd}"
  log_err "Elapsed before failure: $(format_duration "${total_elapsed}")"
  exit "${code}"
}
trap 'on_error "$LINENO" "$BASH_COMMAND" "$?"' ERR

# ---------- Config ----------
SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_WORKSPACE_ROOT=""

WS_WEB_DIR="$(systemctl --user show -p WorkingDirectory --value workspace-premiumhub-web.service 2>/dev/null || true)"
WS_API_DIR="$(systemctl --user show -p WorkingDirectory --value workspace-premiumhub-api.service 2>/dev/null || true)"

if [[ -n "${WS_WEB_DIR}" ]]; then
  DEFAULT_WORKSPACE_ROOT="$(dirname "${WS_WEB_DIR}")"
elif [[ -n "${WS_API_DIR}" ]]; then
  DEFAULT_WORKSPACE_ROOT="$(dirname "${WS_API_DIR}")"
else
  DEFAULT_WORKSPACE_ROOT="${SCRIPT_ROOT}"
fi

PROJECT_ROOT="${PROJECT_ROOT:-${DEFAULT_WORKSPACE_ROOT}}"
BRANCH="${BRANCH:-main}"

FRONTEND_DIR="${PROJECT_ROOT}/premiumhub-web"
BACKEND_DIR="${PROJECT_ROOT}/premiumhub-api"

# Build behavior
RUN_GO_MOD_TIDY="${RUN_GO_MOD_TIDY:-0}"   # default: jangan mutate deps saat deploy
NPM_FLAGS="${NPM_FLAGS:---include=dev --no-audit --no-fund}"

# Git update behavior (deterministic by default)
# - ff-only   : aman, gagal kalau diverged (default)
# - rebase    : pull --rebase
# - hard-reset: paksa samakan ke origin/<branch> (drop local changes)
GIT_UPDATE_MODE="${GIT_UPDATE_MODE:-ff-only}"

# Default ketat: stop kalau working tree kotor supaya deploy bisa diprediksi
ALLOW_DIRTY_TREE="${ALLOW_DIRTY_TREE:-0}"
AUTO_STASH="${AUTO_STASH:-0}"
SHOW_GIT_SUMMARY="${SHOW_GIT_SUMMARY:-1}"

# Deterministic build plan controls
AUTO_DETECT_CHANGES="${AUTO_DETECT_CHANGES:-1}"
FORCE_FULL_BUILD="${FORCE_FULL_BUILD:-0}"
FORCE_FE_BUILD="${FORCE_FE_BUILD:-0}"
FORCE_BE_BUILD="${FORCE_BE_BUILD:-0}"
FORCE_NPM_CI="${FORCE_NPM_CI:-0}"
RUN_SOSMED_WALLET_SMOKE_TEST="${RUN_SOSMED_WALLET_SMOKE_TEST:-0}"
SOSMED_WALLET_SMOKE_TEST_PATTERN="${SOSMED_WALLET_SMOKE_TEST_PATTERN:-TestCreateSosmedOrderWalletJAP(Smoke|RefundSmoke)}"

# Workspace service runtime mode
# - API: auto|go-run|binary
# - WEB: auto|dev|prod
WORKSPACE_API_RUN_MODE="${WORKSPACE_API_RUN_MODE:-auto}"
WORKSPACE_WEB_RUN_MODE="${WORKSPACE_WEB_RUN_MODE:-auto}"

# Local orchestration mode:
# - auto : when current checkout is not the real workspace root on server,
#          delegate to remote over SSH. This makes local Windows/WSL clones
#          behave as launchers, while direct execution on server still runs in-place.
# - 1    : always delegate to remote over SSH
# - 0    : never delegate; run directly on current machine
REMOTE_DEPLOY_ENABLED="${REMOTE_DEPLOY_ENABLED:-auto}"
REMOTE_DEPLOY_HOST="${REMOTE_DEPLOY_HOST:-rdpkhorur}"
REMOTE_PROJECT_ROOT="${REMOTE_PROJECT_ROOT:-/home/ubuntu/openclaw-vcp/profiles/openai-codex/shared/workspace/premium-hub}"
REMOTE_SCRIPT_PATH="${REMOTE_SCRIPT_PATH:-${REMOTE_PROJECT_ROOT}/workspace-deploy}"

EXPECT_BE_BINARY_ARTIFACT=1
EXPECT_FE_BUILD_ARTIFACT=1

DEPLOY_STATE_DIR="${DEPLOY_STATE_DIR:-${PROJECT_ROOT}/.deploy-state}"
LAST_SUCCESS_COMMIT_FILE="${LAST_SUCCESS_COMMIT_FILE:-${DEPLOY_STATE_DIR}/workspace-last-success-commit}"

# Health targets (workspace ports)
FE_HEALTH_URL="${FE_HEALTH_URL:-http://127.0.0.1:3005/}"
BE_HEALTH_URL="${BE_HEALTH_URL:-http://127.0.0.1:18082/healthz}"

# Workspace systemd services ONLY
SERVICES=(
  "workspace-premiumhub-api.service"
  "workspace-premiumhub-web.service"
)

# ---------- Helpers ----------
find_backend_entry() {
  if [[ -f "${BACKEND_DIR}/cmd/main.go" ]]; then
    echo "cmd/main.go"
    return 0
  fi
  if [[ -f "${BACKEND_DIR}/main.go" ]]; then
    echo "main.go"
    return 0
  fi
  return 1
}

wait_for_http() {
  local url="$1"
  local label="$2"
  local attempts="${3:-15}"
  local sleep_s="${4:-2}"

  local i
  for ((i=1; i<=attempts; i++)); do
    if curl -fsS "${url}" >/dev/null; then
      log_ok "${label} healthy (${url})"
      return 0
    fi
    log_warn "${label} belum ready (attempt ${i}/${attempts}), retry ${sleep_s}s..."
    sleep "${sleep_s}"
  done

  log_err "${label} tidak healthy setelah ${attempts} percobaan: ${url}"
  return 1
}

service_execstart_value() {
  local svc="$1"
  systemctl --user show -p ExecStart --value "${svc}" 2>/dev/null || true
}

detect_api_run_mode_from_execstart() {
  local execstart="$1"

  if grep -qiE '\bgo run\b' <<<"${execstart}"; then
    echo "go-run"
    return 0
  fi

  if grep -qiE 'workspace-premiumhub-api|/bin/premiumhub-api' <<<"${execstart}"; then
    echo "binary"
    return 0
  fi

  echo "unknown"
}

detect_web_run_mode_from_execstart() {
  local execstart="$1"

  if grep -qiE '\bnpm run dev\b|\bnext dev\b' <<<"${execstart}"; then
    echo "dev"
    return 0
  fi

  if grep -qiE '\bnpm run start\b|\bnext start\b' <<<"${execstart}"; then
    echo "prod"
    return 0
  fi

  echo "unknown"
}

git_is_dirty() {
  [[ -n "$(git status --porcelain)" ]]
}

git_head_summary() {
  git show -s --format='%h %ci %s' "$1"
}

collect_changed_files() {
  local baseline_commit="${1:-}"

  CHANGED_FILES_TMP="$(mktemp)"
  : > "${CHANGED_FILES_TMP}"

  if [[ -n "${baseline_commit}" ]]; then
    git diff --name-only "${baseline_commit}..HEAD" >> "${CHANGED_FILES_TMP}" || true
  fi

  git diff --name-only >> "${CHANGED_FILES_TMP}" || true
  git diff --name-only --cached >> "${CHANGED_FILES_TMP}" || true
  git ls-files --others --exclude-standard >> "${CHANGED_FILES_TMP}" || true

  # Ignore generated artifacts so build decision stays deterministic.
  awk '
    NF == 0 { next }
    /^\.deploy-state\// { next }
    /^premiumhub-web\/\.next\// { next }
    /^premiumhub-web\/node_modules\// { next }
    /^premiumhub-web\/\.turbo\// { next }
    /^premiumhub-api\/bin\// { next }
    { print }
  ' "${CHANGED_FILES_TMP}" | sort -u > "${CHANGED_FILES_TMP}.sorted"
  mv "${CHANGED_FILES_TMP}.sorted" "${CHANGED_FILES_TMP}"
}

has_changed_prefix() {
  local prefix="$1"
  grep -qE "^${prefix}/" "${CHANGED_FILES_TMP}"
}

has_changed_exact() {
  local path="$1"
  grep -qFx "${path}" "${CHANGED_FILES_TMP}"
}

has_backend_runtime_changes() {
  awk '
    /^premiumhub-api\// {
      if ($0 ~ /(^premiumhub-api\/testdata\/)|(^premiumhub-api\/.*\/testdata\/)/) { next }
      if ($0 ~ /_test\.go$/) { next }
      found=1
    }
    END { exit(found ? 0 : 1) }
  ' "${CHANGED_FILES_TMP}"
}

is_worktree_dirty() {
  if ! git diff --quiet || ! git diff --cached --quiet; then
    return 0
  fi

  [[ -n "$(git ls-files --others --exclude-standard)" ]]
}

is_truthy() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_falsey() {
  case "${1:-}" in
    0|false|FALSE|no|NO|off|OFF)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

normalize_compare_path() {
  local path="${1:-}"

  if [[ -z "${path}" ]]; then
    printf '\n'
    return 0
  fi

  if [[ -d "${path}" ]]; then
    (
      cd "${path}" && pwd -P
    )
    return 0
  fi

  if [[ "${path}" == "/" ]]; then
    printf '/\n'
  else
    printf '%s\n' "${path%/}"
  fi
}

is_remote_project_root_here() {
  local normalized_script_root normalized_remote_root

  normalized_script_root="$(normalize_compare_path "${SCRIPT_ROOT}")"
  normalized_remote_root="$(normalize_compare_path "${REMOTE_PROJECT_ROOT}")"

  [[ -n "${normalized_remote_root}" && "${normalized_script_root}" == "${normalized_remote_root}" ]]
}

should_delegate_remote_deploy() {
  if is_truthy "${WORKSPACE_DEPLOY_REMOTE_HOP:-0}"; then
    return 1
  fi

  if is_truthy "${REMOTE_DEPLOY_ENABLED}"; then
    return 0
  fi

  if is_falsey "${REMOTE_DEPLOY_ENABLED}"; then
    return 1
  fi

  ! is_remote_project_root_here
}

print_remote_export_if_set() {
  local name="$1"
  if [[ -v "${name}" ]]; then
    printf 'export %s=%q\n' "${name}" "${!name}"
  fi
}

warn_if_local_branch_not_pushed() {
  local counts ahead behind

  if ! git -C "${SCRIPT_ROOT}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi

  if ! git -C "${SCRIPT_ROOT}" rev-parse --abbrev-ref '@{upstream}' >/dev/null 2>&1; then
    return 0
  fi

  if ! git -C "${SCRIPT_ROOT}" fetch --quiet origin "${BRANCH}" >/dev/null 2>&1; then
    log_warn "Gagal refresh origin/${BRANCH} sebelum cek ahead/behind. Status warning mungkin stale."
  fi

  counts="$(git -C "${SCRIPT_ROOT}" rev-list --left-right --count "HEAD...@{upstream}" 2>/dev/null || true)"
  if [[ -z "${counts}" ]]; then
    return 0
  fi

  read -r ahead behind <<<"${counts}"
  ahead="${ahead:-0}"
  behind="${behind:-0}"

  if (( ahead > 0 )); then
    log_warn "Local branch ahead ${ahead} commit dari upstream. Remote deploy akan pakai origin/${BRANCH}, jadi pastikan perubahan sudah di-push."
  fi

  if (( behind > 0 )); then
    log_warn "Local branch behind ${behind} commit dari upstream. Remote deploy akan pull origin/${BRANCH} terbaru."
  fi
}

run_remote_deploy() {
  local env_name
  local -a forwarded_env_names=(
    "RUN_GO_MOD_TIDY"
    "NPM_FLAGS"
    "GIT_UPDATE_MODE"
    "ALLOW_DIRTY_TREE"
    "AUTO_STASH"
    "SHOW_GIT_SUMMARY"
    "AUTO_DETECT_CHANGES"
    "FORCE_FULL_BUILD"
    "FORCE_FE_BUILD"
    "FORCE_BE_BUILD"
    "FORCE_NPM_CI"
    "RUN_SOSMED_WALLET_SMOKE_TEST"
    "SOSMED_WALLET_SMOKE_TEST_PATTERN"
    "WORKSPACE_API_RUN_MODE"
    "WORKSPACE_WEB_RUN_MODE"
    "FE_HEALTH_URL"
    "BE_HEALTH_URL"
  )

  command -v ssh >/dev/null || {
    log_err "Command ssh tidak ditemukan. Jalankan skrip ini dari environment yang punya OpenSSH/Git Bash."
    exit 1
  }

  warn_if_local_branch_not_pushed

  step_start "REMOTE DEPLOY ORCHESTRATION"
  log_info "Delegating deploy ke server via SSH"
  log_info "Local root  : ${SCRIPT_ROOT}"
  log_info "Remote host : ${REMOTE_DEPLOY_HOST}"
  log_info "Remote root : ${REMOTE_PROJECT_ROOT}"
  log_info "Remote script: ${REMOTE_SCRIPT_PATH}"
  log_warn "Bootstrap remote akan git pull dulu supaya server pakai commit terbaru yang sudah di-push"

  {
    printf 'set -Eeuo pipefail\n'
    printf 'cd %q\n' "${REMOTE_PROJECT_ROOT}"
    printf 'git fetch origin %q\n' "${BRANCH}"
    printf 'git checkout %q\n' "${BRANCH}"
    printf 'git pull --ff-only origin %q\n' "${BRANCH}"
    printf 'export WORKSPACE_DEPLOY_REMOTE_HOP=1\n'
    printf 'export PROJECT_ROOT=%q\n' "${REMOTE_PROJECT_ROOT}"
    printf 'export BRANCH=%q\n' "${BRANCH}"

    for env_name in "${forwarded_env_names[@]}"; do
      print_remote_export_if_set "${env_name}"
    done

    printf 'exec bash %q\n' "${REMOTE_SCRIPT_PATH}"
  } | ssh "${REMOTE_DEPLOY_HOST}" bash -s

  step_done "REMOTE DEPLOY ORCHESTRATION"
}

if should_delegate_remote_deploy; then
  run_remote_deploy
  exit 0
fi

# ---------- Precheck ----------
step_start "PRECHECK"
command -v git >/dev/null
command -v npm >/dev/null
command -v go >/dev/null
command -v curl >/dev/null
command -v systemctl >/dev/null
command -v awk >/dev/null
command -v sort >/dev/null

[[ -d "${FRONTEND_DIR}" ]] || { log_err "Frontend dir tidak ditemukan: ${FRONTEND_DIR}"; exit 1; }
[[ -d "${BACKEND_DIR}" ]] || { log_err "Backend dir tidak ditemukan: ${BACKEND_DIR}"; exit 1; }

BACKEND_ENTRY="$(find_backend_entry)" || { log_err "Entry backend tidak ditemukan (cmd/main.go atau main.go)"; exit 1; }
log_info "Backend entry: ${BACKEND_ENTRY}"

if [[ -f "${BACKEND_DIR}/go.mod" ]]; then
  GO_DIRECTIVE="$(awk '/^go[[:space:]]+[0-9]+(\.[0-9]+){1,2}$/ {print $2; exit}' "${BACKEND_DIR}/go.mod" || true)"
  if [[ -z "${GO_DIRECTIVE}" ]]; then
    log_warn "go.mod directive tidak terbaca valid. Contoh valid: 'go 1.22.6'"
  else
    log_info "go.mod directive: ${GO_DIRECTIVE}"
  fi
fi

for svc in "${SERVICES[@]}"; do
  [[ "${svc}" == workspace-* ]] || {
    log_err "Unsafe service target terdeteksi: ${svc}"
    exit 1
  }
  if ! systemctl --user status "${svc}" >/dev/null 2>&1; then
    log_warn "Service ${svc} belum terdaftar aktif. Pastikan unit file sudah dibuat."
  fi
done

API_EXECSTART_VALUE="$(service_execstart_value "workspace-premiumhub-api.service")"
WEB_EXECSTART_VALUE="$(service_execstart_value "workspace-premiumhub-web.service")"

if [[ "${WORKSPACE_API_RUN_MODE}" == "auto" ]]; then
  WORKSPACE_API_RUN_MODE="$(detect_api_run_mode_from_execstart "${API_EXECSTART_VALUE}")"
fi
if [[ "${WORKSPACE_WEB_RUN_MODE}" == "auto" ]]; then
  WORKSPACE_WEB_RUN_MODE="$(detect_web_run_mode_from_execstart "${WEB_EXECSTART_VALUE}")"
fi

case "${WORKSPACE_API_RUN_MODE}" in
  go-run|binary)
    ;;
  unknown)
    log_warn "API service mode tidak terdeteksi jelas dari ExecStart. Default validation tetap jalan."
    ;;
  *)
    log_err "WORKSPACE_API_RUN_MODE tidak valid: ${WORKSPACE_API_RUN_MODE} (allowed: auto|go-run|binary)"
    exit 1
    ;;
esac

case "${WORKSPACE_WEB_RUN_MODE}" in
  dev|prod)
    ;;
  unknown)
    log_warn "Web service mode tidak terdeteksi jelas dari ExecStart. Default validation tetap jalan."
    ;;
  *)
    log_err "WORKSPACE_WEB_RUN_MODE tidak valid: ${WORKSPACE_WEB_RUN_MODE} (allowed: auto|dev|prod)"
    exit 1
    ;;
esac

if [[ "${WORKSPACE_API_RUN_MODE}" == "go-run" ]]; then
  EXPECT_BE_BINARY_ARTIFACT=0
fi
if [[ "${WORKSPACE_WEB_RUN_MODE}" == "dev" ]]; then
  EXPECT_FE_BUILD_ARTIFACT=0
fi

log_info "Workspace API mode: ${WORKSPACE_API_RUN_MODE}"
log_info "Workspace Web mode: ${WORKSPACE_WEB_RUN_MODE}"

if [[ "${EXPECT_BE_BINARY_ARTIFACT}" == "0" ]]; then
  log_warn "API service mode go-run -> binary artifact bukan runtime source of truth"
fi
if [[ "${EXPECT_FE_BUILD_ARTIFACT}" == "0" ]]; then
  log_warn "Web service mode dev -> .next/BUILD_ID bukan runtime source of truth"
fi

step_done "PRECHECK"

# ---------- Pull latest code ----------
step_start "PULL LATEST CODE"
cd "${PROJECT_ROOT}"

STASH_CREATED=0
STASH_REF=""

log_info "Starting git update on branch: ${BRANCH}"
git fetch origin "${BRANCH}"
git checkout "${BRANCH}"

if [[ "${SHOW_GIT_SUMMARY}" == "1" ]]; then
  log_info "Local HEAD : $(git_head_summary HEAD)"
  log_info "Remote HEAD: $(git_head_summary "origin/${BRANCH}")"
fi

if git_is_dirty; then
  if [[ "${ALLOW_DIRTY_TREE}" == "1" ]]; then
    if [[ "${AUTO_STASH}" == "1" ]]; then
      log_warn "Working tree kotor, AUTO_STASH=1 -> stash sebelum update"
      STASH_REF="workspace-deploy-autostash-$(date +%s)"
      git stash push -u -m "${STASH_REF}"
      STASH_CREATED=1
    else
      log_warn "Working tree kotor, ALLOW_DIRTY_TREE=1 + AUTO_STASH=0 -> lanjut tanpa stash"
    fi
  else
    log_err "Working tree kotor. Workspace deploy dihentikan biar deterministic."
    git status --short || true
    log_err "Override (jika sadar risikonya): ALLOW_DIRTY_TREE=1 (opsional AUTO_STASH=1)"
    exit 1
  fi
fi

case "${GIT_UPDATE_MODE}" in
  ff-only)
    git pull --ff-only origin "${BRANCH}"
    ;;
  rebase)
    git pull --rebase origin "${BRANCH}"
    ;;
  hard-reset)
    log_warn "GIT_UPDATE_MODE=hard-reset -> reset ke origin/${BRANCH} (local changes dibuang)"
    git reset --hard "origin/${BRANCH}"
    git clean -fd
    ;;
  *)
    log_err "GIT_UPDATE_MODE tidak valid: ${GIT_UPDATE_MODE}. Gunakan: ff-only|rebase|hard-reset"
    exit 1
    ;;
esac

if [[ "${STASH_CREATED}" == "1" ]]; then
  log_info "Mencoba restore perubahan lokal (git stash pop)..."
  if git stash pop; then
    log_ok "Perubahan lokal berhasil direstore"
  else
    log_warn "Stash pop conflict. Periksa manual via 'git status' dan 'git stash list'"
    exit 1
  fi
fi

LOCAL_HEAD="$(git rev-parse HEAD)"
REMOTE_HEAD="$(git rev-parse "origin/${BRANCH}")"
if [[ "${LOCAL_HEAD}" == "${REMOTE_HEAD}" ]]; then
  log_ok "HEAD synced ke origin/${BRANCH}: $(git rev-parse --short HEAD)"
else
  log_warn "HEAD lokal beda dari origin/${BRANCH}. local=$(git rev-parse --short "${LOCAL_HEAD}") remote=$(git rev-parse --short "${REMOTE_HEAD}")"
fi

if [[ "${SHOW_GIT_SUMMARY}" == "1" ]]; then
  log_info "Deploy commit: $(git_head_summary HEAD)"
fi

step_done "PULL LATEST CODE"

# ---------- Build Plan (deterministic) ----------
step_start "PLAN BUILD STRATEGY"
cd "${PROJECT_ROOT}"

CURRENT_HEAD="$(git rev-parse HEAD)"
CURRENT_HEAD_SHORT="$(git rev-parse --short HEAD)"

BASELINE_COMMIT=""
BASELINE_VALID=0
if [[ -f "${LAST_SUCCESS_COMMIT_FILE}" ]]; then
  BASELINE_COMMIT="$(tr -d ' \n\r\t' < "${LAST_SUCCESS_COMMIT_FILE}")"

  if [[ -n "${BASELINE_COMMIT}" ]] && git cat-file -e "${BASELINE_COMMIT}^{commit}" 2>/dev/null; then
    if git merge-base --is-ancestor "${BASELINE_COMMIT}" HEAD; then
      BASELINE_VALID=1
      log_info "Baseline commit detected: $(git rev-parse --short "${BASELINE_COMMIT}")"
    else
      log_warn "Baseline commit bukan ancestor HEAD (history rewrite/rebase). Fallback ke full build."
    fi
  else
    log_warn "Baseline commit invalid/unknown. Fallback ke full build."
  fi
else
  log_warn "Baseline commit belum ada. Fallback ke full build."
fi

if [[ "${BASELINE_VALID}" == "1" ]]; then
  collect_changed_files "${BASELINE_COMMIT}"
else
  collect_changed_files
fi

CHANGED_COUNT="$(wc -l < "${CHANGED_FILES_TMP}" | tr -d ' ')"
if (( CHANGED_COUNT > 0 )); then
  local_preview_count="$(( CHANGED_COUNT > 25 ? 25 : CHANGED_COUNT ))"
  log_info "Changed files considered: ${CHANGED_COUNT} (showing ${local_preview_count})"
  sed -n "1,${local_preview_count}p" "${CHANGED_FILES_TMP}" | sed 's/^/  - /'
else
  log_info "Tidak ada perubahan file yang terdeteksi dari baseline + working tree"
fi

SHOULD_BUILD_FE=1
SHOULD_BUILD_BE=1
SHOULD_RESTART_SERVICES=1
NEEDS_NPM_CI=1
PLAN_REASON="default-full"

if [[ "${FORCE_FULL_BUILD}" == "1" ]]; then
  PLAN_REASON="FORCE_FULL_BUILD=1"
elif [[ "${AUTO_DETECT_CHANGES}" != "1" ]]; then
  PLAN_REASON="AUTO_DETECT_CHANGES=0"
elif [[ "${BASELINE_VALID}" != "1" ]]; then
  PLAN_REASON="baseline-missing-or-invalid"
else
  SHOULD_BUILD_FE=0
  SHOULD_BUILD_BE=0
  PLAN_REASON="auto-detect-from-git-delta"

  if has_changed_prefix "premiumhub-web"; then
    SHOULD_BUILD_FE=1
  fi
  if has_changed_prefix "premiumhub-api"; then
    if has_backend_runtime_changes; then
      SHOULD_BUILD_BE=1
    else
      log_info "Backend delta hanya file test/testdata -> skip BE build"
    fi
  fi
fi

if [[ "${FORCE_FE_BUILD}" == "1" ]]; then
  SHOULD_BUILD_FE=1
  PLAN_REASON="${PLAN_REASON} + FORCE_FE_BUILD"
fi

if [[ "${FORCE_BE_BUILD}" == "1" ]]; then
  SHOULD_BUILD_BE=1
  PLAN_REASON="${PLAN_REASON} + FORCE_BE_BUILD"
fi

if [[ "${SHOULD_BUILD_FE}" == "0" && "${EXPECT_FE_BUILD_ARTIFACT}" == "1" && ! -f "${FRONTEND_DIR}/.next/BUILD_ID" ]]; then
  log_warn "FE artifact .next/BUILD_ID tidak ada -> force FE build"
  SHOULD_BUILD_FE=1
fi

if [[ "${SHOULD_BUILD_FE}" == "0" && "${EXPECT_FE_BUILD_ARTIFACT}" == "0" && ! -d "${FRONTEND_DIR}/node_modules" ]]; then
  log_warn "Web mode dev + node_modules tidak ada -> force FE prep step"
  SHOULD_BUILD_FE=1
fi

if [[ "${SHOULD_BUILD_BE}" == "0" && "${EXPECT_BE_BINARY_ARTIFACT}" == "1" && ! -x "${BACKEND_DIR}/bin/workspace-premiumhub-api" ]]; then
  log_warn "BE artifact bin/workspace-premiumhub-api tidak ada -> force BE build"
  SHOULD_BUILD_BE=1
fi

SHOULD_RESTART_SERVICES=0
if [[ "${SHOULD_BUILD_FE}" == "1" || "${SHOULD_BUILD_BE}" == "1" ]]; then
  SHOULD_RESTART_SERVICES=1
fi

NEEDS_NPM_CI=0
NPM_CI_REASON="skip (deps unchanged)"
if [[ "${SHOULD_BUILD_FE}" == "1" ]]; then
  if [[ "${FORCE_NPM_CI}" == "1" ]]; then
    NEEDS_NPM_CI=1
    NPM_CI_REASON="FORCE_NPM_CI=1"
  elif [[ ! -d "${FRONTEND_DIR}/node_modules" ]]; then
    NEEDS_NPM_CI=1
    NPM_CI_REASON="node_modules missing"
  elif [[ "${BASELINE_VALID}" != "1" ]]; then
    NEEDS_NPM_CI=1
    NPM_CI_REASON="baseline missing/invalid"
  elif has_changed_exact "premiumhub-web/package-lock.json"; then
    NEEDS_NPM_CI=1
    NPM_CI_REASON="package-lock.json changed"
  elif has_changed_exact "premiumhub-web/package.json"; then
    NEEDS_NPM_CI=1
    NPM_CI_REASON="package.json changed"
  else
    NEEDS_NPM_CI=0
    NPM_CI_REASON="package manifest unchanged"
  fi
fi

log_info "Plan reason: ${PLAN_REASON}"
log_info "Build plan: FE=${SHOULD_BUILD_FE}, BE=${SHOULD_BUILD_BE}, npm_ci=${NEEDS_NPM_CI} (${NPM_CI_REASON})"
log_info "Runtime actions: restart_services=${SHOULD_RESTART_SERVICES}, sosmed_wallet_smoke_test=${RUN_SOSMED_WALLET_SMOKE_TEST}"
log_info "Service alignment: web_mode=${WORKSPACE_WEB_RUN_MODE} expect_fe_artifact=${EXPECT_FE_BUILD_ARTIFACT}, api_mode=${WORKSPACE_API_RUN_MODE} expect_be_artifact=${EXPECT_BE_BINARY_ARTIFACT}"

if is_worktree_dirty; then
  log_warn "Working tree masih dirty/untracked. Untuk baseline paling stabil, commit dulu perubahan."
fi

step_done "PLAN BUILD STRATEGY"

# ---------- Build Frontend ----------
if [[ "${SHOULD_BUILD_FE}" == "1" ]]; then
  step_start "BUILD FRONTEND"
  cd "${FRONTEND_DIR}"

  if [[ "${NEEDS_NPM_CI}" == "1" ]]; then
    log_info "Installing frontend dependencies (npm ci ${NPM_FLAGS})..."
    npm ci ${NPM_FLAGS}
  else
    log_info "Skipping npm ci (${NPM_CI_REASON})"
  fi

  if [[ "${WORKSPACE_WEB_RUN_MODE}" == "dev" ]]; then
    log_info "Workspace web mode=dev -> skip npm run build (artifact tidak dipakai service)"
  else
    log_info "Starting frontend build (npm run build)..."
    npm run build
  fi

  step_done "BUILD FRONTEND"
else
  log_info "BUILD FRONTEND skipped (no FE changes detected)"
fi

# ---------- Build Backend ----------
if [[ "${SHOULD_BUILD_BE}" == "1" ]]; then
  step_start "BUILD BACKEND"
  cd "${BACKEND_DIR}"

  if [[ "${RUN_GO_MOD_TIDY}" == "1" ]]; then
    log_info "RUN_GO_MOD_TIDY=1 -> running go mod tidy..."
    go mod tidy
  else
    log_info "Skipping go mod tidy (set RUN_GO_MOD_TIDY=1 jika diperlukan)"
  fi

  if [[ "${WORKSPACE_API_RUN_MODE}" == "go-run" ]]; then
    TMP_BE_CHECK_BIN="$(mktemp /tmp/workspace-premiumhub-api-compile-check.XXXXXX)"
    rm -f "${TMP_BE_CHECK_BIN}"
    log_info "Workspace API mode=go-run -> compile-check backend (tanpa artifact runtime)"
    go build -o "${TMP_BE_CHECK_BIN}" "${BACKEND_ENTRY}"
    rm -f "${TMP_BE_CHECK_BIN}"
  else
    mkdir -p bin
    log_info "Starting backend build (go build -o bin/workspace-premiumhub-api ${BACKEND_ENTRY})..."
    go build -o bin/workspace-premiumhub-api "${BACKEND_ENTRY}"
  fi

  step_done "BUILD BACKEND"
else
  log_info "BUILD BACKEND skipped (no BE changes detected)"
fi

# ---------- Smoke Test ----------
step_start "SMOKE TEST"

if [[ "${EXPECT_FE_BUILD_ARTIFACT}" == "1" ]]; then
  log_info "Checking FE build artifact (.next/BUILD_ID)..."
  [[ -f "${FRONTEND_DIR}/.next/BUILD_ID" ]]
else
  log_info "Skipping FE artifact check (web mode dev)"
fi

if [[ "${EXPECT_BE_BINARY_ARTIFACT}" == "1" ]]; then
  log_info "Checking BE build artifact (bin/workspace-premiumhub-api)..."
  [[ -x "${BACKEND_DIR}/bin/workspace-premiumhub-api" ]]
else
  log_info "Skipping BE binary artifact check (api mode go-run)"
fi

if is_truthy "${RUN_SOSMED_WALLET_SMOKE_TEST}"; then
  if [[ "${CGO_ENABLED:-1}" == "0" ]]; then
    log_warn "Skipping optional sosmed wallet smoke test karena CGO_ENABLED=0"
  else
    log_info "Running optional sosmed wallet smoke test (${SOSMED_WALLET_SMOKE_TEST_PATTERN})..."
    (
      cd "${BACKEND_DIR}"
      go test ./internal/handler -run "${SOSMED_WALLET_SMOKE_TEST_PATTERN}" -count=1
    )
  fi
else
  log_info "Skipping optional sosmed wallet smoke test (RUN_SOSMED_WALLET_SMOKE_TEST=0)"
fi

step_done "SMOKE TEST"

# ---------- Restart Workspace Services ----------
if [[ "${SHOULD_RESTART_SERVICES}" == "1" ]]; then
  step_start "RESTART WORKSPACE SERVICES"
  for svc in "${SERVICES[@]}"; do
    log_info "Restarting ${svc} ..."
    systemctl --user restart "${svc}"
    systemctl --user is-active --quiet "${svc}"
    log_ok "${svc} is active"
  done
  step_done "RESTART WORKSPACE SERVICES"
else
  log_info "RESTART WORKSPACE SERVICES skipped (no runtime artifact/source changes detected)"
fi

# ---------- Workspace health check ----------
step_start "WORKSPACE HEALTHCHECK"

log_info "Checking frontend endpoint: ${FE_HEALTH_URL}"
wait_for_http "${FE_HEALTH_URL}" "Workspace Frontend" 20 1

log_info "Checking backend health endpoint: ${BE_HEALTH_URL}"
wait_for_http "${BE_HEALTH_URL}" "Workspace Backend(healthz)" 10 1

step_done "WORKSPACE HEALTHCHECK"

# ---------- Save deterministic baseline ----------
step_start "SAVE DEPLOY BASELINE"
mkdir -p "${DEPLOY_STATE_DIR}"
printf '%s\n' "${CURRENT_HEAD}" > "${LAST_SUCCESS_COMMIT_FILE}"
log_info "Saved baseline commit: ${CURRENT_HEAD_SHORT} -> ${LAST_SUCCESS_COMMIT_FILE}"
step_done "SAVE DEPLOY BASELINE"

DEPLOY_END_TS="$(date +%s)"
DEPLOY_TOTAL_SEC=$((DEPLOY_END_TS - DEPLOY_START_TS))

log_ok "WORKSPACE DEPLOY COMPLETED ✅ (runtime asli tidak disentuh)"
log_info "Total deploy duration: $(format_duration "${DEPLOY_TOTAL_SEC}")"
